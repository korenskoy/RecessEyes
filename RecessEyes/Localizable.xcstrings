    "break.overlay.tip.body": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "yavaş-yavaş beş dəfə göz qırp — bu, gözyaşı qatını buynuz qişa boyunca yayır."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "blink slowly five times — it spreads the tear film across your cornea."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "parpadea lento cinco veces — extiende la película lagrimal sobre tu córnea."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پنج بار آرام پلک بزن — این لایه اشکی را روی قرنیه پخش می‌کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "медленно моргните пять раз — это распределит слёзную плёнку по роговице."
          }
        }
      }
    },
