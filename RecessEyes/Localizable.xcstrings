        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "20-20-20 rhythm · gentle reminder, then a 20-second look-away."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritmo 20-20-20 · aviso suave y mirada de 20 segundos."
