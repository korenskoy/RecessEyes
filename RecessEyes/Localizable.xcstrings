    "apps.footer": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Sürətlə əlavə etmək üçün proqramları Finder-dən sürüşdürün."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag apps from Finder to add them quickly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra apps desde Finder para añadirlas rápido."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای افزودن سریع، برنامه‌ها را از Finder بکشید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите приложения из Finder, чтобы быстро добавить."
          }
        }
      }
    },
    "apps.heading": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu proqramlar aktiv olduqda taymeri dayandır"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pause timer when these apps are active"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausar temporizador cuando estas apps estén activas"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "وقتی این برنامه‌ها فعال‌اند تایمر را متوقف کن"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ставить таймер на паузу, когда эти приложения активны"
          }
        }
      }
    },
    "apps.search.placeholder": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Proqramları süzgəcdən keçir"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filter applications"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Filtrar aplicaciones"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "فیلتر برنامه‌ها"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фильтр приложений"
          }
        }
      }
    },
    "apps.subheading": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Diqqət tələb edən, ekranı az işıqlandıran proqram önə çıxdıqda RecessEyes iş taymerini dayandırır. Taymerin gözləməsini istədiyiniz proqramları seçin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RecessEyes keeps the work timer paused while a focused, screen-light app is in front. Toggle the apps that should keep your timer waiting."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "RecessEyes mantiene el temporizador en pausa cuando una app de poca pantalla está en primer plano. Activa las apps que deben pausar el temporizador."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "وقتی یک برنامه متمرکز با مصرف نور کم در پیش‌زمینه است، RecessEyes تایمر کار را متوقف نگه می‌دارد. برنامه‌هایی را که باید تایمر را در انتظار نگه دارند فعال کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "RecessEyes держит рабочий таймер на паузе, пока на экране сфокусированное «лёгкое» приложение. Включите приложения, которые должны останавливать таймер."
          }
        }
      }
    },
    "break.overlay.done": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazırdır"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
