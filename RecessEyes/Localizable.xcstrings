    "break.overlay.title.expired": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Fasilə bitdi"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Break complete"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descanso completado"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "استراحت تمام شد"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перерыв закончен"
          }
        }
      }
    },
    "break.overlay.expired": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "İşə davam etmək üçün bu pəncərəni bağlayın"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Close this overlay to resume work"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra esta pantalla para reanudar el trabajo"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای ادامه‌ی کار این پنجره را ببند"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Закройте окно, чтобы продолжить работу"
          }
        }
      }
    },
    "break.overlay.lede": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Pəncərə yanında və ya otağın o tərəfində bir nöqtə seç və taymer bitənə qədər gözlərini istirahət etdir."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a point near a window or across the room and let your eyes relax until the timer ends."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un punto cerca de una ventana o al otro lado del cuarto y deja que tus ojos descansen hasta que termine el temporizador."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نقطه‌ای نزدیک یک پنجره یا آن‌سوی اتاق انتخاب کن و بگذار چشمانت تا پایان تایمر استراحت کنند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите точку у окна или в дальнем углу комнаты и дайте глазам отдохнуть, пока идёт таймер."
          }
        }
      }
    },
    "break.overlay.lock": {
      "localizations": {
